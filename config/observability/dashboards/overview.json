{
  "annotations": {
    "list": []
  },
  "description": "Keleustes operator overview — manager liveness, reconcile health, CRD lifecycle. See docs/plans/2026-05-observability-stack.md §6.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Manager up/down",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "min(up{job=\"controller-manager-metrics\"})",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"text": "Down", "color": "red"}}, "type": "value"},
            {"options": {"1": {"text": "Up", "color": "green"}}, "type": "value"}
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Reconcile rate by controller (per second)",
      "type": "timeseries",
      "gridPos": {"x": 6, "y": 0, "w": 9, "h": 8},
      "targets": [
        {
          "expr": "sum by (controller) (rate(controller_runtime_reconcile_total{job=\"controller-manager-metrics\"}[5m]))",
          "legendFormat": "{{controller}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 3,
      "title": "Reconcile error rate by controller (per second)",
      "type": "timeseries",
      "gridPos": {"x": 15, "y": 0, "w": 9, "h": 8},
      "targets": [
        {
          "expr": "sum by (controller) (rate(controller_runtime_reconcile_errors_total{job=\"controller-manager-metrics\"}[5m]))",
          "legendFormat": "{{controller}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 4,
      "title": "Reconcile latency p95 by controller",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (controller, le) (rate(controller_runtime_reconcile_time_seconds_bucket{job=\"controller-manager-metrics\"}[5m])))",
          "legendFormat": "{{controller}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 5,
      "title": "Workqueue depth by controller",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "max by (name) (workqueue_depth{job=\"controller-manager-metrics\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "SyncRun phase distribution",
      "type": "piechart",
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum by (phase) (keleustes_syncrun_phase{phase!=\"\"} == 1)",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Promotion phase distribution",
      "type": "piechart",
      "gridPos": {"x": 8, "y": 16, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum by (phase) (keleustes_promotion_phase{phase!=\"\"} == 1)",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Blocked promotions",
      "type": "stat",
      "gridPos": {"x": 16, "y": 16, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum(keleustes_promotion_phase{phase=\"Blocked\"} == 1)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["keleustes", "operator", "overview"],
  "templating": {"list": []},
  "time": {"from": "now-3h", "to": "now"},
  "title": "Keleustes Operator Overview",
  "uid": "keleustes-operator-overview",
  "version": 1
}
